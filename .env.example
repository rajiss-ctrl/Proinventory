# ─── Firebase project credentials ───────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is listed in .gitignore.

VITE_FIREBASE_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ─── Guest demo account ──────────────────────────────────────────────────────
# Create this account manually in Firebase Auth console, no Firestore doc needed.
VITE_GUEST_EMAIL=your_guest_email@example.com
VITE_GUEST_PASSWORD=your_guest_password

# ─── Super Admin seed ────────────────────────────────────────────────────────
# Used ONLY by scripts/seed-superadmin.mjs (run once, then remove from .env).
# Never used by the Vite app at runtime.
VITE_SUPERADMIN_EMAIL=your_superadmin_email@example.com
VITE_SUPERADMIN_PASSWORD=your_superadmin_password
