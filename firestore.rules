rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* =========================================================
       HELPER FUNCTIONS
    ========================================================= */

    function signedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return signedIn() && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function isActiveUser() {
      return userExists() && userData().status == "active";
    }

    function isSuperAdmin() {
      return isActiveUser() && userData().isSuperAdmin == true;
    }

    function userCompanyId() {
      return userData().companyId;
    }

    function userRole() {
      return userData().role;
    }

    function belongsToCompany(companyId) {
      return isActiveUser() && userCompanyId() == companyId;
    }

    // ── FIX 1: guest role gets full owner access ──────────────
    // The old rules only checked "company_owner" but guest users
    // have role == "company_owner" after seeding, so this works.
    // We keep the explicit guest check as a safety net.
    function isOwner() {
      return isActiveUser() && (
        userRole() == "company_owner" ||
        userRole() == "guest"
      );
    }

    function isCompanyAdmin() {
      return isActiveUser() && userRole() == "company_admin";
    }

    function isStaff() {
      return isActiveUser() && userRole() == "staff";
    }

    function isOwnerOrAdmin() {
      return isOwner() || isCompanyAdmin();
    }

    // ── FIX 2: safe permission helpers ────────────────────────
    // Old rules accessed userData().permissions[module].read which
    // throws if the permissions map is missing or malformed.
    // New helpers short-circuit on isOwnerOrAdmin() FIRST, then
    // fall through to the permissions map only for staff.
    function hasModuleRead(module) {
      return isSuperAdmin()
        || isOwnerOrAdmin()
        || (module == "dashboard"      && userData().permissions.dashboard.read      == true)
        || (module == "products"       && userData().permissions.products.read       == true)
        || (module == "categories"     && userData().permissions.categories.read     == true)
        || (module == "orders"         && userData().permissions.orders.read         == true)
        || (module == "purchaseOrders" && userData().permissions.purchaseOrders.read == true)
        || (module == "stock"          && userData().permissions.stock.read          == true)
        || (module == "suppliers"      && userData().permissions.suppliers.read      == true)
        || (module == "customers"      && userData().permissions.customers.read      == true)
        || (module == "reports"        && userData().permissions.reports.read        == true)
        || (module == "settings"       && userData().permissions.settings.read       == true)
        || (module == "users"          && userData().permissions.users.read          == true);
    }

    function hasModuleWrite(module) {
      return isSuperAdmin()
        || isOwnerOrAdmin()
        || (module == "products"       && userData().permissions.products.write      == true)
        || (module == "categories"     && userData().permissions.categories.write    == true)
        || (module == "orders"         && userData().permissions.orders.write        == true)
        || (module == "purchaseOrders" && userData().permissions.purchaseOrders.write == true)
        || (module == "stock"          && userData().permissions.stock.write          == true)
        || (module == "suppliers"      && userData().permissions.suppliers.write      == true)
        || (module == "customers"      && userData().permissions.customers.write      == true)
        || (module == "reports"        && userData().permissions.reports.write        == true)
        || (module == "settings"       && userData().permissions.settings.write       == true)
        || (module == "users"          && userData().permissions.users.write          == true);
    }

    function hasModuleDelete(module) {
      return isSuperAdmin()
        || isOwner()
        || (module == "products"       && userData().permissions.products.delete      == true)
        || (module == "categories"     && userData().permissions.categories.delete    == true)
        || (module == "orders"         && userData().permissions.orders.delete        == true)
        || (module == "purchaseOrders" && userData().permissions.purchaseOrders.delete == true)
        || (module == "stock"          && userData().permissions.stock.delete          == true)
        || (module == "suppliers"      && userData().permissions.suppliers.delete      == true)
        || (module == "customers"      && userData().permissions.customers.delete      == true)
        || (module == "users"          && userData().permissions.users.delete          == true);
    }

    function hasStockAdjust() {
      return isSuperAdmin()
        || isOwnerOrAdmin()
        || userData().permissions.stock.adjust == true;
    }

    /* =========================================================
       GLOBAL USER PROFILE  /users/{uid}
    ========================================================= */
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow read: if isSuperAdmin();

      // Self-registration: user creates their own profile.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.companyId != ""
        && request.resource.data.isSuperAdmin == false
        && request.resource.data.role != "super_admin";

      // Owner/admin creating a staff member's profile during invite.
      allow create: if isSuperAdmin()
        || (isOwnerOrAdmin()
            && request.resource.data.uid == uid
            && request.resource.data.companyId == userCompanyId()
            && request.resource.data.isSuperAdmin == false
            && request.resource.data.role in ["company_admin", "staff"]);

      // User updates own safe fields
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid          == resource.data.uid
        && request.resource.data.isSuperAdmin == resource.data.isSuperAdmin
        && request.resource.data.role         != "super_admin";

      // Owner/admin updates company members
      allow update: if isSuperAdmin()
        || (isOwnerOrAdmin() && userCompanyId() == resource.data.companyId);

      allow delete: if isSuperAdmin();
    }

    /* =========================================================
       COMPANY ROOT  /companies/{companyId}
    ========================================================= */
    match /companies/{companyId} {
      allow read: if isSuperAdmin() || belongsToCompany(companyId);

      // Allow company creation during registration
      allow create: if isSuperAdmin()
        || (signedIn() && request.resource.data.ownerId == request.auth.uid);

      allow update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());

      allow delete: if isSuperAdmin();
    }

    /* =========================================================
       COMPANY USERS  /companies/{companyId}/users/{uid}
    ========================================================= */
    match /companies/{companyId}/users/{uid} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin())
        || (belongsToCompany(companyId) && request.auth.uid == uid);

      allow create: if isSuperAdmin()
        || (belongsToCompany(companyId)
            && isOwnerOrAdmin()
            && request.resource.data.uid == uid
            && request.resource.data.companyId == companyId
            && request.resource.data.role in ["company_admin", "staff"])
        || (signedIn()
            && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.companyId == companyId);

      allow update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());

      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       PRODUCTS  /companies/{companyId}/products/{productId}
    ========================================================= */
    match /companies/{companyId}/products/{productId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("products"));

      allow create: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleWrite("products"));

      allow update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());

      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       CATEGORIES  /companies/{companyId}/categories/{categoryId}
    ========================================================= */
    match /companies/{companyId}/categories/{categoryId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("categories"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       INVENTORY  /companies/{companyId}/inventory/{inventoryId}
    ========================================================= */
    match /companies/{companyId}/inventory/{inventoryId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("stock"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleWrite("stock"));
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       COUNTERS  /companies/{companyId}/counters/{counterId}
    ========================================================= */
    match /companies/{companyId}/counters/{counterId} {
      allow read, create, update: if (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if (belongsToCompany(companyId) && isOwnerOrAdmin());
    }

    /* =========================================================
       SUPPLIERS  /companies/{companyId}/suppliers/{supplierId}
    ========================================================= */
    match /companies/{companyId}/suppliers/{supplierId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("suppliers"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       CUSTOMERS  /companies/{companyId}/customers/{customerId}
    ========================================================= */
    match /companies/{companyId}/customers/{customerId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("customers"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleWrite("customers"));
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       ORDERS  /companies/{companyId}/orders/{orderId}
    ========================================================= */
    match /companies/{companyId}/orders/{orderId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("orders"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleWrite("orders"));
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       PURCHASE ORDERS  /companies/{companyId}/purchaseOrders/{poId}
    ========================================================= */
    match /companies/{companyId}/purchaseOrders/{poId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("purchaseOrders"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    /* =========================================================
       TRANSFERS  /companies/{companyId}/transfers/{transferId}
    ========================================================= */
    match /companies/{companyId}/transfers/{transferId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("stock"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());
    }

    // Transfer items subcollection
    match /companies/{companyId}/transfers/{transferId}/items/{itemId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("stock"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin();
    }

    /* =========================================================
       STOCK MOVEMENTS  /companies/{companyId}/stockMovements/{id}
       Append-only audit trail — never edit or delete from client.
    ========================================================= */
    match /companies/{companyId}/stockMovements/{movementId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("stock"));
      allow create: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasStockAdjust());
      allow update: if false;
      allow delete: if isSuperAdmin();
    }

    /* =========================================================
       WAREHOUSES & NESTED INVENTORY
    ========================================================= */
    match /companies/{companyId}/warehouses/{warehouseId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("stock"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwner());

      // 🚨 FIX FOR TRANSFERS INVENTORY READ/WRITE PERMISSIONS 🚨
      match /inventory/{inventoryId} {
        allow read: if isSuperAdmin()
          || (belongsToCompany(companyId) && hasModuleRead("stock"));
        allow create, update: if isSuperAdmin()
          || (belongsToCompany(companyId) && hasModuleWrite("stock"));
        allow delete: if isSuperAdmin()
          || (belongsToCompany(companyId) && isOwner());
      }
    }

    /* =========================================================
       REPORTS  /companies/{companyId}/reports/{reportId}
    ========================================================= */
    match /companies/{companyId}/reports/{reportId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("reports"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin();
    }

    /* =========================================================
       SETTINGS  /companies/{companyId}/settings/{settingId}
    ========================================================= */
    match /companies/{companyId}/settings/{settingId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("settings"));
      allow create, update: if isSuperAdmin()
        || (belongsToCompany(companyId) && isOwnerOrAdmin());
      allow delete: if isSuperAdmin();
    }

    /* =========================================================
       AUDIT LOGS  /companies/{companyId}/auditLogs/{logId}
    ========================================================= */
    match /companies/{companyId}/auditLogs/{logId} {
      allow read: if isSuperAdmin()
        || (belongsToCompany(companyId) && hasModuleRead("reports"));
      allow create, update, delete: if isSuperAdmin();
    }

  }
}